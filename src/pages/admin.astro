---
import Layout from '../layouts/Layout.astro';
import sql from '../db/index.js';

// Fetch available groups for dropdown
let availableGroups = [];
try {
  const groupsData = await sql`
    SELECT id, name FROM groups ORDER BY name ASC
  `;
  availableGroups = groupsData;
} catch (error) {
  console.error('Error fetching groups:', error);
  availableGroups = [];
}
---

<Layout title="Admin Scanner">
  <div class="admin-container">
    <h1 class="glow-title">Admin NFC Portal</h1>

    <div class="scanner-ui">
<!-- Minecraft Observer Face via Actual Texture -->
      <div class="observer-wrapper">
        <img id="observer-img" class="observer-img" src="/observer_front.png" alt="Observer" />
      </div>

      <p class="status-msg" id="status-message">Waiting for NFC scan...</p>

      <button class="mc-button scan-btn" id="simulate-scan">START SCANNER</button>
      <button class="mc-button" id="test-write-btn" style="margin-top: 1rem; width: 100%; background: rgba(150, 120, 60, 0.6); font-size: 0.9rem; border-color: #aa5500;">🛠️ Test NFC Write (Debug)</button>

      <!-- Modal for new user prompt -->
      <div class="new-user-form mc-panel" id="new-user-form" style="display: none; margin-top: 2rem; width: 100%;">
        <h3>New NFC Card Detected!</h3>
        <p style="color: #8b949e; margin-bottom: 1rem;">This badge isn't assigned to anyone yet.</p>
        <div style="margin-top: 1rem; text-align: left;">
          <label for="profile-name" style="color: #c9d1d9; display: block; margin-bottom: 0.5rem;">Enter Profile Name:</label>
          <input type="text" id="profile-name" class="mc-input" placeholder="BlockBreaker99" />
        </div>
        <div style="margin-top: 1rem; text-align: left;">
          <label for="group-select" style="color: #c9d1d9; display: block; margin-bottom: 0.5rem;">Assign to Group:</label>
          <select id="group-select" class="mc-input">
             {availableGroups.length > 0 ? (
               availableGroups.map((grp) => (
                 <option value={grp.id}>{grp.name}</option>
               ))
             ) : (
               <option value="">No groups available</option>
             )}
          </select>
        </div>
        <button class="mc-button" id="save-new-user" style="margin-top: 1.5rem; width: 100%;">Register & Log Attendance</button>
      </div>

      <!-- UID Writing Instructions -->
      <div class="uid-instructions mc-panel" id="uid-instructions" style="display: none; margin-top: 2rem; border-color: var(--mc-accent); background: rgba(60, 133, 39, 0.1);">
        <h3 style="color: #55ff55; margin-top: 0;">✓ User Registered!</h3>
        <p style="color: #c9d1d9; margin: 1rem 0;">Your NFC sticker profile URL:</p>
        <div style="background: #0d1117; padding: 1rem; border-radius: 4px; border: 1px solid #30363d; margin: 1rem 0; font-family: var(--font-minecraft-ten); font-size: 0.9rem; color: #55ff55; text-align: center; word-break: break-all; overflow-wrap: break-word;" id="profile-url-display"></div>
        <button class="mc-button" id="write-to-sticker-btn" style="margin-top: 1rem; width: 100%; background: rgba(60, 133, 39, 0.5);">Write to NFC Sticker</button>
        <p style="color: #ffaa00; font-size: 0.85rem; margin: 0.5rem 0;"><strong>⚠ Keep tag in range for entire write!</strong></p>
        <button class="mc-button" id="test-write-btn" style="margin-top: 0.5rem; width: 100%; background: rgba(150, 120, 60, 0.4); font-size: 0.9rem;">Test NFC (Write "TEST")</button>
        <p style="color: #8b949e; font-size: 0.9rem; margin: 1rem 0;">Or manually write using <strong>TagWriter by NXP</strong> or <strong>Nfc Tools</strong></p>
        <p style="color: #8b949e; font-size: 0.85rem; margin: 0;">UID: <span id="uid-display" style="color: #55ff55;"></span></p>
        <button class="mc-button" id="close-instructions" style="margin-top: 1rem; width: 100%; background: rgba(60, 133, 39, 0.2);">Continue Scanning</button>
      </div>

      <div class="success-alert mc-panel" id="success-alert" style="display: none; margin-top: 2rem; border-color: var(--mc-accent); background: rgba(35, 134, 54, 0.1);">
        <h3 style="color: #55ff55; margin:0;">Attendance Logged!</h3>
      </div>
    </div>
  </div>
</Layout>

<script>
  let currentNUID = '';
  let isRegistering = false;
  let isWriting = false;

  const scanBtn = document.getElementById('simulate-scan');
  const statusMsg = document.getElementById('status-message');
  const observerImg = document.getElementById('observer-img') as HTMLImageElement;
  const newUserForm = document.getElementById('new-user-form');
  const successAlert = document.getElementById('success-alert');
  const saveBtn = document.getElementById('save-new-user');
  const profileNameInput = document.getElementById('profile-name') as HTMLInputElement;
  const groupSelect = document.getElementById('group-select') as HTMLSelectElement;

  async function logAttendance(uid: string) {
    try {
      const response = await fetch('/api/scan', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ uid })
      });

      const result = await response.json();

      if (response.ok) {
        if (statusMsg) {
          statusMsg.innerText = `✓ ${result.attendee.name} - Day ${result.attendee.days_attended}`;
          statusMsg.style.color = '#55ff55';
        }
        if (successAlert) successAlert.style.display = 'block';
        if (observerImg) observerImg.className = 'observer-img success-glow';
      } else if (response.status === 404) {
        // Unknown NFC card - show friendly message
        currentNUID = uid;
        isRegistering = true;
        if (statusMsg) {
          statusMsg.innerText = `New badge detected! Enter the child's name...`;
          statusMsg.style.color = '#ffaa00';
        }
        if (newUserForm) newUserForm.style.display = 'block';
        if (observerImg) observerImg.className = 'observer-img scan-pulse';
        return;
      }
    } catch (error) {
      if (statusMsg) {
        statusMsg.innerText = `Error: ${error instanceof Error ? error.message : 'Unknown error'}`;
        statusMsg.style.color = '#ff5555';
      }
    }

    // Reset after 5 seconds
    setTimeout(() => {
      if (observerImg) observerImg.className = 'observer-img scan-pulse';
      if (statusMsg) {
        statusMsg.innerText = 'Scanner Active! Tap your tag...';
        statusMsg.style.color = '#55ffff';
      }
      if (newUserForm) newUserForm.style.display = 'none';
      if (successAlert) successAlert.style.display = 'none';
    }, 5000);
  }

  scanBtn?.addEventListener('click', async () => {
    if (newUserForm) newUserForm.style.display = 'none';
    if (successAlert) successAlert.style.display = 'none';

    if (!('NDEFReader' in window)) {
      if (statusMsg) statusMsg.innerText = "Error: Web NFC is not supported. Use Android Chrome to scan.";
      if (observerImg) observerImg.className = 'observer-img error-pulse';
      return;
    }

    try {
      // @ts-ignore
      const ndef = new NDEFReader();
      await ndef.scan();

      if (observerImg) observerImg.className = 'observer-img scan-pulse';
      if (statusMsg) {
        statusMsg.innerText = "Scanner Active! Tap your tag...";
        statusMsg.style.color = '#55ffff';
      }

      ndef.addEventListener("readingerror", () => {
        if (isWriting || isRegistering) return;
        if (statusMsg) {
          statusMsg.innerText = "Could not read tag. Try again!";
          statusMsg.style.color = '#ff5555';
        }
      });

      ndef.addEventListener("reading", ({ serialNumber }: any) => {
        if (isWriting || isRegistering) return;
        if (observerImg) observerImg.className = 'observer-img';
        const uid = serialNumber || 'UNKNOWN';
        logAttendance(uid);
      });
    } catch (error: any) {
      if (statusMsg) {
        statusMsg.innerText = `Permission Denied or Error: ${error.message}`;
        statusMsg.style.color = '#ff5555';
      }
      if (observerImg) observerImg.className = 'observer-img error-pulse';
    }
  });

  saveBtn?.addEventListener('click', async () => {
    const profileName = profileNameInput?.value.trim();
    const groupId = groupSelect?.value;

    if (!profileName || !groupId) {
      if (statusMsg) {
        statusMsg.innerText = 'Please fill in all fields!';
        statusMsg.style.color = '#ff5555';
      }
      return;
    }

    try {
      const response = await fetch('/api/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          uid: currentNUID,
          name: profileName,
          groupId: parseInt(groupId),
          isNewSticker: currentNUID === 'UNKNOWN' || !currentNUID
        })
      });

      const result = await response.json();

      if (response.ok) {
        if (newUserForm) newUserForm.style.display = 'none';

        // Check if UID was generated (brand new sticker)
        if (result.isNewSticker && result.generatedUID) {
          // Show UID writing instructions
          const uidInstructions = document.getElementById('uid-instructions');
          const uidDisplay = document.getElementById('uid-display');
          const profileUrlDisplay = document.getElementById('profile-url-display');

          const profileUrl = `${window.location.origin}/profile/${encodeURIComponent(profileName)}`;

          if (uidDisplay) {
            uidDisplay.innerText = result.generatedUID;
          }
          if (profileUrlDisplay) {
            profileUrlDisplay.innerText = profileUrl;
          }
          if (uidInstructions) uidInstructions.style.display = 'block';
          currentNUID = result.generatedUID;
          (window as any).currentProfileName = profileName;
          (window as any).currentProfileUrl = profileUrl;
        } else {
          // Already written sticker or manual registration
          if (statusMsg) {
            statusMsg.innerText = `✓ ${profileName} registered and Day 1 logged!`;
            statusMsg.style.color = '#55ff55';
          }
          if (successAlert) successAlert.style.display = 'block';
        }

        // Clear form
        if (profileNameInput) profileNameInput.value = '';
        if (groupSelect) groupSelect.value = groupSelect.options[0].value;

        isRegistering = false;
      } else {
        if (statusMsg) {
          statusMsg.innerText = 'Registration failed. User may already exist!';
          statusMsg.style.color = '#ff5555';
        }
      }
    } catch (error) {
      if (statusMsg) {
        statusMsg.innerText = `Error: ${error instanceof Error ? error.message : 'Unknown error'}`;
        statusMsg.style.color = '#ff5555';
      }
    }

    // Reset after 5 seconds (unless showing UID instructions)
    setTimeout(() => {
      const uidInstructions = document.getElementById('uid-instructions');
      if (!uidInstructions || uidInstructions.style.display === 'none') {
        if (observerImg) observerImg.className = 'observer-img scan-pulse';
        if (statusMsg) {
          statusMsg.innerText = 'Scanner Active! Tap your tag...';
          statusMsg.style.color = '#55ffff';
        }
        if (successAlert) successAlert.style.display = 'none';
      }
    }, 5000);
  });

  const closeInstructionsBtn = document.getElementById('close-instructions');
  closeInstructionsBtn?.addEventListener('click', () => {
    const uidInstructions = document.getElementById('uid-instructions');
    if (uidInstructions) uidInstructions.style.display = 'none';

    if (observerImg) observerImg.className = 'observer-img scan-pulse';
    if (statusMsg) {
      statusMsg.innerText = 'Scanner Active! Tap your tag...';
      statusMsg.style.color = '#55ffff';
    }
  });

  const writeToStickerBtn = document.getElementById('write-to-sticker-btn');
  writeToStickerBtn?.addEventListener('click', async () => {
    isWriting = true;
    if (!('NDEFReader' in window)) {
      if (statusMsg) statusMsg.innerText = "Error: Web NFC is not supported. Use Android Chrome.";
      console.error("NDEFReader not available");
      isWriting = false;
      return;
    }

    try {
      const profileUrl = (window as any).currentProfileUrl || '';
      const uid = currentNUID || '';

      if (!profileUrl || !uid) {
        if (statusMsg) statusMsg.innerText = 'Error: Missing profile URL or UID';
        console.error('Missing URL or UID', { profileUrl, uid });
        isWriting = false;
        return;
      }

      if (statusMsg) {
        statusMsg.innerText = 'Ready to write... Tap NFC sticker';
        statusMsg.style.color = '#ffaa00';
      }

      // Create records in proper NDEF format
      const records = [
        {
          recordType: 'url',
          data: profileUrl
        },
        {
          recordType: 'text',
          lang: 'en',
          data: `vcs_uid:${uid}`
        }
      ];

      console.log('Writing records:', records);

      // @ts-ignore
      const writer = new NDEFReader();
      await writer.write({ records });

      console.log('✓ Successfully wrote to NFC tag');

      if (statusMsg) {
        statusMsg.innerText = '✓ Profile URL written to sticker!';
        statusMsg.style.color = '#55ff55';
      }

      // Close instructions after success
      setTimeout(() => {
        const uidInstructions = document.getElementById('uid-instructions');
        if (uidInstructions) uidInstructions.style.display = 'none';
        if (observerImg) observerImg.className = 'observer-img success-glow';
        if (statusMsg) {
          statusMsg.innerText = 'Scanner Active! Tap your tag...';
          statusMsg.style.color = '#55ffff';
        }
        isWriting = false;
        isRegistering = false;
      }, 3000);
    } catch (error: any) {
      console.error('NFC Write Error:', error);
      console.error('Error name:', error.name);
      console.error('Error message:', error.message);

      if (statusMsg) {
        const errorMsg = error.name === 'NotAllowedError'
          ? 'NFC write cancelled or tag removed. Try again.'
          : error.name === 'NotSupportedError'
          ? 'Tag type not supported for writing.'
          : error.name === 'InvalidStateError'
          ? 'NFC transaction aborted. Ensure tag is in range.'
          : `Error: ${error.message}`;

        statusMsg.innerText = errorMsg;
        statusMsg.style.color = '#ff5555';
      }
      if (observerImg) observerImg.className = 'observer-img error-pulse';
      isWriting = false;
    }
  });

  // Test NFC Write - Simple debug function
  const testWriteBtn = document.getElementById('test-write-btn');
  testWriteBtn?.addEventListener('click', async () => {
    isWriting = true;
    if (!('NDEFReader' in window)) {
      if (statusMsg) statusMsg.innerText = "Error: Web NFC not supported. Use Android Chrome.";
      isWriting = false;
      return;
    }

    try {
      if (statusMsg) {
        statusMsg.innerText = 'Test: Hold tag in range NOW...';
        statusMsg.style.color = '#ffaa00';
      }

      const records = [
        {
          recordType: 'text',
          lang: 'en',
          data: 'TEST_VCS_2026'
        }
      ];

      console.log('Test write - records:', records);

      // @ts-ignore
      const writer = new NDEFReader();
      await writer.write({ records });

      console.log('✓ Test write succeeded!');

      if (statusMsg) {
        statusMsg.innerText = '✓ Test write successful! Tag is writable.';
        statusMsg.style.color = '#55ff55';
      }
      
      setTimeout(() => {
        isWriting = false;
      }, 3000);
    } catch (error: any) {
      console.error('Test write failed:', error);

      if (statusMsg) {
        const errorMsg = error.name === 'NotAllowedError'
          ? '❌ Cancelled. Hold tag in range longer!'
          : error.name === 'NotSupportedError'
          ? '❌ Tag type not supported for writing'
          : error.name === 'InvalidStateError'
          ? '❌ Tag removed. Try again.'
          : error.name === 'SecurityError'
          ? '❌ Permission denied. Enable NFC permissions.'
          : `❌ ${error.message}`;

        statusMsg.innerText = errorMsg;
        statusMsg.style.color = '#ff5555';
      }
      isWriting = false;
    }
  });
</script>

<style>
  .admin-container {
    max-width: 500px;
    margin: 0 auto;
    text-align: center;
  }

  .glow-title {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: #f0f6fc;
    background-image: linear-gradient(135deg, #f0f6fc 0%, #a4e698 50%, #3C8527 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 10px rgba(60, 133, 39, 0.4));
  }

  .scanner-ui {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .observer-wrapper {
    margin-bottom: 2rem;
    border-radius: 8px;
    overflow: hidden;
  }

  .observer-img {
    width: 160px;
    height: 160px;
    image-rendering: pixelated;
    transition: filter 0.3s ease;
  }

  .scan-pulse {
    animation: scanner-pulse 1.5s infinite alternate;
  }

  .error-pulse {
    filter: drop-shadow(0 0 15px rgba(255, 85, 85, 0.8)) hue-rotate(320deg) saturate(200%);
  }

  .success-glow {
    filter: drop-shadow(0 0 15px rgba(85, 255, 85, 0.8)) hue-rotate(90deg) saturate(200%);
  }

  @keyframes scanner-pulse {
    0%   { filter: drop-shadow(0 0 5px rgba(85, 255, 255, 0.3)); }
    100% { filter: drop-shadow(0 0 20px rgba(85, 255, 255, 0.8)) brightness(1.2); }
  }

  .status-msg {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    color: #8b949e;
  }

  .scan-btn {
    width: 100%;
    margin-bottom: 1rem;
  }
</style>
