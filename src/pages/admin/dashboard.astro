---
import Layout from '../../layouts/Layout.astro';
import sql from '../../db/index.js';

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');

try { await sql`ALTER TABLE attendees ADD COLUMN IF NOT EXISTS is_teacher BOOLEAN DEFAULT false`; } catch (e) {}
try { await sql`ALTER TABLE attendees ADD COLUMN IF NOT EXISTS avatar_url TEXT`; } catch (e) {}

const attendeesResult = await sql`
  SELECT a.id, a.name, a.group_id, g.name as group_name, a.emeralds, COALESCE(a.is_teacher, false) as is_teacher, a.avatar_url
  FROM attendees a
  LEFT JOIN groups g ON a.group_id = g.id
  ORDER BY a.name ASC
`;

const groupsResult = await sql`SELECT id, name FROM groups ORDER BY name ASC`;  

const attendees = attendeesResult || [];
const groups = groupsResult || [];
---

<Layout title="Admin Dashboard">
  <div class="admin-container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
      <h1 class="glow-title" style="margin-bottom: 0;">Admin Dashboard</h1>
      <div style="display: flex; gap: 1rem;">
        <a href="/admin/scanner" class="mc-button" style="background: rgba(31, 111, 235, 0.4); text-decoration: none; padding: 0.5rem 1rem;">NFC Scanner</a>
        <a href="/attendance" class="mc-button" style="background: rgba(60, 133, 39, 0.4); text-decoration: none; padding: 0.5rem 1rem;">Live Rankings</a>
      </div>
    </div>

    <!-- Groups Admin Panel -->
    <div class="mc-panel" style="padding: 0; overflow: hidden; background: #0d1117; margin-bottom: 3rem;">
      <h2 style="padding: 1rem 1rem 0 1rem; margin: 0; color: #ffb86c;">Groups Manager</h2>
      <div class="table-responsive" style="padding: 1rem;">
        <table class="mc-table">
          <thead>
            <tr>
              <th style="width: 60px; text-align: center;">ID</th>
              <th style="text-align: left;">Group Name</th>
              <th style="text-align: right; width: 200px;">Actions</th>
            </tr>
          </thead>
          <tbody>
            {groups.map(grp => (
              <tr data-group-id={grp.id}>
                <td data-label="ID" style="text-align: center; color: #8b949e;">#{grp.id}</td>
                <td data-label="Group Name">
                  <input type="text" class="edit-group-name mc-input" value={grp.name} style="width: 100%; max-width: 300px;" />
                </td>
                <td data-label="Actions" style="text-align: right;">
                  <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                    <button class="btn-save-group mc-button" style="padding: 0.5rem; font-size: 0.8rem; background: rgba(35, 134, 54, 0.4);" disabled>Saved</button>
                    <button class="btn-delete-group mc-button" style="padding: 0.5rem; font-size: 0.8rem; background: rgba(255, 85, 85, 0.3); border-color: #ff5555; color: #ff5555;">Del</button>
                  </div>
                </td>
              </tr>
            ))}
            {groups.length === 0 && (
              <tr><td colspan="3" style="text-align: center; padding: 2rem; color: #8b949e;">No groups found.</td></tr>
            )}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Users Admin Panel -->
    <div class="mc-panel" style="padding: 0; overflow: hidden; background: #0d1117;">
      <h2 style="padding: 1rem 1rem 0 1rem; margin: 0; color: #55FFFF;">User & Emerald Manager</h2>
      <div class="table-responsive" style="padding: 1rem;">
        <table class="mc-table">
          <thead>
            <tr>
              <th style="text-align: left; width: 250px;">Profile</th>
              <th style="text-align: center; width: 80px;">Teacher?</th>
              <th style="text-align: center;">Group</th>
              <th style="text-align: center; color: #55FF55; width: 150px;">Emeralds</th>
              <th style="text-align: right; width: 120px;">Actions</th>
            </tr>
          </thead>
          <tbody>
            {attendees.map(user => {
              const defaultAvatar = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%238b949e'%3E%3Cpath d='M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z'/%3E%3C/svg%3E";
              const avatarUrl = user.avatar_url ? user.avatar_url : defaultAvatar;
              return (
              <tr class="user-row" data-user-id={user.id}>
                <td data-label="Profile">
                  <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                      <img src={avatarUrl} alt="Avatar" class="avatar-head" onerror="this.src='/favicon.svg'" style="cursor: pointer; object-fit: cover; border-radius: 50%;" title="Click to take a photo" />
                      <input type="text" class="edit-name mc-input" value={user.name} style="width: 100%; font-weight: bold; font-size: 1.1rem; padding: 0.25rem 0.5rem; color: #c9d1d9;" />
                    </div>
                    <input type="file" accept="image/*" capture="environment" class="edit-avatar-file" style="display: none;" />
                    <input type="text" class="edit-avatar-url mc-input" value={user.avatar_url || ''} style="display: none;" />
                  </div>
                </td>

                <td data-label="Teacher?" style="text-align: center;">
                  <input type="checkbox" class="edit-teacher mc-input" checked={user.is_teacher} style="width: 1.5rem; height: 1.5rem; cursor: pointer;" />
                </td>

                <td data-label="Group" style="text-align: center;">
                  <select class="edit-group mc-input" style="width: 100%; max-width: 200px; margin: 0 auto; display: block;" disabled={user.is_teacher}>       
                    <option value="">No Group</option>
                    {groups.map(g => (
                      <option value={g.id} selected={user.group_id === g.id}>{g.name}</option>
                    ))}
                  </select>
                </td>

                <td data-label="Emeralds" style="text-align: center;">
                  <div style="display: flex; align-items: center; justify-content: center; gap: 0.5rem;">    
                    <button class="btn-emerald-sub mc-button" style="padding: 0 0.5rem; min-width: 32px;" disabled={user.is_teacher}>-</button>
                    <input type="number" class="edit-emeralds mc-input hide-arrows" value={user.is_teacher ? 0 : (user.emeralds || 0)} style="width: 60px; text-align: center; color: #55FF55; font-family: var(--font-minecraft-ten); padding: 0.25rem;" disabled={user.is_teacher} />
                    <button class="btn-emerald-add mc-button" style="padding: 0 0.5rem; min-width: 32px;" disabled={user.is_teacher}>+</button>
                  </div>
                </td>

                <td data-label="Actions" style="text-align: right;">
                  <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                    <button class="btn-save mc-button" style="padding: 0.5rem; font-size: 0.8rem; background: rgba(35, 134, 54, 0.4);" disabled>Saved</button>
                    <button class="btn-delete mc-button" style="padding: 0.5rem; font-size: 0.8rem; background: rgba(255, 85, 85, 0.3); border-color: #ff5555; color: #ff5555;" title={`Delete ${user.name}`}>Del</button>
                  </div>
                </td>
              </tr>
            )})}

            {attendees.length === 0 && (
              <tr>
                <td colspan="5" style="text-align: center; padding: 2rem; color: #8b949e;">No users found. Go scan someone to add them!</td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>

<style>
  .admin-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .glow-title {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: #f0f6fc;
    background-image: linear-gradient(135deg, #f0f6fc 0%, #a4e698 50%, #3C8527 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 10px rgba(60, 133, 39, 0.4));
  }

  .mc-table {
    width: 100%;
    border-collapse: collapse;
    color: var(--mc-text);
  }

  .mc-table th {
    padding: 1rem;
    text-align: left;
    background-color: #161b22;
    border-bottom: 1px solid #30363d;
    font-family: var(--font-minecraft-ten);
    color: #8b949e;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    white-space: nowrap;
    vertical-align: middle;
  }

  .mc-table td {
    padding: 1rem;
    border-bottom: 1px solid rgba(48, 54, 61, 0.5);
    background-color: transparent;
    vertical-align: middle;
  }

  .mc-table tr:hover td {
    background-color: rgba(255, 255, 255, 0.02);
  }

  .mc-table tr:last-child td {
    border-bottom: none;
  }

  .table-responsive {
    width: 100%;
    overflow-x: auto;
  }

  .avatar-head {
    width: 32px;
    height: 32px;
    image-rendering: pixelated;
    border-radius: 4px;
    border: 1px solid #30363d;
    transition: opacity 0.2s;
  }

  .avatar-head:hover {
    opacity: 0.8;
  }

  /* Hide up/down arrows in number inputs */
  .hide-arrows::-webkit-outer-spin-button,
  .hide-arrows::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .hide-arrows {
    -moz-appearance: textfield;
  }
  
  .mc-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .mc-input:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    background: rgba(0,0,0,0.5);
  }

  @media (max-width: 768px) {
    .table-responsive {
      overflow-x: hidden;
    }

    .mc-table, .mc-table tbody, .mc-table tr {
      display: block;
      width: 100%;
    }

    .mc-table td {
      display: block;
      box-sizing: border-box;
      width: 100%;
    }

    .mc-table thead {
      display: none;
    }

    .mc-table tr {
      border-bottom: 3px solid #30363d;
      padding-bottom: 0.5rem;
      margin-bottom: 0.5rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // --- USERS MANAGER ---
    const userRows = document.querySelectorAll('tbody tr.user-row');

    userRows.forEach(row => {
      const id = row.getAttribute('data-user-id');
      const nameInput = row.querySelector('.edit-name') as HTMLInputElement;    
      const groupSelect = row.querySelector('.edit-group') as HTMLSelectElement;
      const teacherCheck = row.querySelector('.edit-teacher') as HTMLInputElement;
      const emeraldsInput = row.querySelector('.edit-emeralds') as HTMLInputElement;
      const avatarUrlInput = row.querySelector('.edit-avatar-url') as HTMLInputElement;
      const avatarFileInput = row.querySelector('.edit-avatar-file') as HTMLInputElement;
      const avatarImg = row.querySelector('.avatar-head') as HTMLImageElement;

      const saveBtn = row.querySelector('.btn-save') as HTMLButtonElement;      
      const delBtn = row.querySelector('.btn-delete') as HTMLButtonElement;      
      const btnAdd = row.querySelector('.btn-emerald-add') as HTMLButtonElement;
      const btnSub = row.querySelector('.btn-emerald-sub') as HTMLButtonElement;

      // Trigger Camera / File Picker
      avatarImg.addEventListener('click', () => {
        avatarFileInput.click();
      });

      avatarFileInput.addEventListener('change', () => {
        const file = avatarFileInput.files?.[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = (e) => {
            const img = new Image();
            img.onload = () => {
              const canvas = document.createElement('canvas');
              const MAX_WIDTH = 120;
              const MAX_HEIGHT = 120;
              let width = img.width;
              let height = img.height;

              if (width > height) {
                if (width > MAX_WIDTH) {
                  height *= MAX_WIDTH / width;
                  width = MAX_WIDTH;
                }
              } else {
                if (height > MAX_HEIGHT) {
                  width *= MAX_HEIGHT / height;
                  height = MAX_HEIGHT;
                }
              }

              canvas.width = width;
              canvas.height = height;
              const ctx = canvas.getContext('2d');
              ctx?.drawImage(img, 0, 0, width, height);

              const dataUrl = canvas.toDataURL('image/jpeg', 0.8);
              avatarUrlInput.value = dataUrl;
              avatarImg.src = dataUrl;
              enableSave();
            };
            img.src = e.target?.result as string;
          };
          reader.readAsDataURL(file);
        }
      });

      // Handle Teacher Mode logic
      const updateTeacherState = () => {
        const isTeacher = teacherCheck.checked;
        groupSelect.disabled = isTeacher;
        emeraldsInput.disabled = isTeacher;
        btnAdd.disabled = isTeacher;
        btnSub.disabled = isTeacher;
        
        if (isTeacher) {
          groupSelect.value = '';
          emeraldsInput.value = '0';
        }
      };

      // Enable save button when inputs change
      const enableSave = () => {
        saveBtn.disabled = false;
        saveBtn.style.background = 'rgba(31, 111, 235, 0.8)';
        saveBtn.textContent = 'Save';
      };

      teacherCheck.addEventListener('change', () => {
        updateTeacherState();
        enableSave();
      });

      [nameInput, groupSelect, emeraldsInput, avatarUrlInput].forEach(el => {     
        el.addEventListener('input', enableSave);
        el.addEventListener('change', enableSave);
      });

      btnAdd.addEventListener('click', () => {
        if(!teacherCheck.checked) {
          emeraldsInput.value = (parseInt(emeraldsInput.value || '0') + 1).toString();
          enableSave();
        }
      });

      btnSub.addEventListener('click', () => {
        if(!teacherCheck.checked) {
          let val = parseInt(emeraldsInput.value || '0');
          emeraldsInput.value = (val - 1).toString();
          enableSave();
        }
      });

      saveBtn.addEventListener('click', async () => {
        saveBtn.disabled = true;
        saveBtn.textContent = 'Saving...';

        try {
          const res = await fetch(`/api/admin/users/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: nameInput.value,
              group_id: groupSelect.value ? parseInt(groupSelect.value) : null, 
              is_teacher: teacherCheck.checked,
              emeralds: parseInt(emeraldsInput.value || '0'),
              avatar_url: avatarUrlInput.value || null
            })
          });

          if (res.ok) {
            saveBtn.textContent = 'Saved';
            saveBtn.style.background = 'rgba(35, 134, 54, 0.4)';
            
            // update avatar instantly
            let newAvatar = avatarUrlInput.value;
            // Support raw minecraft names for convenience!
            if (newAvatar && !newAvatar.startsWith('http')) {
              newAvatar = `https://minotar.net/avatar/${newAvatar}/32.png`;
            }
            if (!newAvatar) {
              newAvatar = `https://minotar.net/avatar/${nameInput.value}/32.png`;
            }
            avatarImg.src = newAvatar;
          } else {
            throw new Error('Failed');
          }
        } catch (e) {
          saveBtn.disabled = false;
          saveBtn.textContent = 'Error';
          saveBtn.style.background = 'rgba(255, 85, 85, 0.8)';
        }
      });

      delBtn.addEventListener('click', async () => {
        if (confirm(`Are you SURE you want to delete ${nameInput.value}? This removes their data forever.`)) {
          delBtn.disabled = true;
          delBtn.textContent = '...';
          try {
            const res = await fetch(`/api/admin/users/${id}`, { method: 'DELETE' });
            if (res.ok) {
              row.remove();
            } else {
              throw new Error('Failed');
            }
          } catch(e) {
            alert('Failed to delete!');
            delBtn.disabled = false;
            delBtn.textContent = 'Del';
          }
        }
      });
    });

    // --- GROUPS MANAGER ---
    const groupRows = document.querySelectorAll('tbody tr[data-group-id]');
    
    groupRows.forEach(row => {
      const id = row.getAttribute('data-group-id');
      const nameInput = row.querySelector('.edit-group-name') as HTMLInputElement;
      const saveBtn = row.querySelector('.btn-save-group') as HTMLButtonElement;
      const delBtn = row.querySelector('.btn-delete-group') as HTMLButtonElement;

      const enableSave = () => {
        saveBtn.disabled = false;
        saveBtn.style.background = 'rgba(31, 111, 235, 0.8)';
        saveBtn.textContent = 'Save';
      };

      nameInput.addEventListener('input', enableSave);

      saveBtn.addEventListener('click', async () => {
        saveBtn.disabled = true;
        saveBtn.textContent = 'Saving...';

        try {
          const res = await fetch(`/api/admin/groups/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: nameInput.value })
          });

          if (res.ok) {
            saveBtn.textContent = 'Saved';
            saveBtn.style.background = 'rgba(35, 134, 54, 0.4)';
          } else {
            throw new Error('Failed');
          }
        } catch (e) {
          saveBtn.disabled = false;
          saveBtn.textContent = 'Error';
          saveBtn.style.background = 'rgba(255, 85, 85, 0.8)';
        }
      });

      delBtn.addEventListener('click', async () => {
        if (confirm(`Are you SURE you want to delete the group "${nameInput.value}"? Any users in it will be unassigned.`)) {
          delBtn.disabled = true;
          delBtn.textContent = '...';
          try {
            const res = await fetch(`/api/admin/groups/${id}`, { method: 'DELETE' });
            if (res.ok) {
              row.remove();
            } else {
              throw new Error('Failed');
            }
          } catch(e) {
            alert('Failed to delete group!');
            delBtn.disabled = false;
            delBtn.textContent = 'Del';
          }
        }
      });
    });

  });
</script>
