---
import Layout from '../layouts/Layout.astro';

// User mock data
const user = {
  name: "SteveMiner",
  group: "Diamond Diggers",
  groupEmeralds: 64,
  daysAttended: 5,
  rank: "Netherite",
  rankColor: "#443A4B",
  badges: [
    { title: "First Day!", icon: "https://minecraft.wiki/images/Crafting_Table_%28item%29_JE4_BE3.png" },
    { title: "Helped a Friend", icon: "https://minecraft.wiki/images/Golden_Apple_JE2_BE2.png" },
    { title: "Memory Verse Master", icon: "https://minecraft.wiki/images/Enchanted_Book.gif" }
  ]
}
---

<Layout title="My Profile">
  <div class="profile-container">
    <div class="profile-header mc-panel" style="padding: 2rem;">
      <div class="avatar-box">
        <img src={`https://minotar.net/avatar/${user.name}/120.png`} alt={`${user.name}'s Head`} class="avatar-head" onerror="this.src='/favicon.svg'"/>
      </div>
      <div class="player-info">
        <h1 class="player-name">{user.name}</h1>
        <p class="group-title">
          <span class="group-label">GROUP</span>
          <span class="group-name">{user.group}</span>
        </p>
        <p class="emerald-count">
          <img src="https://minecraft.wiki/images/Emerald_JE3_BE3.png" alt="Emerald" width="20" style="vertical-align: middle; margin-right: 8px;" onerror="this.src='data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNkYAAAAAYAAjCB0C8AAAAASUVORK5CYII='"/>
          Group Emeralds: <span style="color: #c9d1d9; font-family: var(--font-minecraft-ten); min-width: 30px; display: inline-block;">{user.groupEmeralds}</span>
        </p>
      </div>
    </div>

    <div class="profile-details">
      <!-- Rank and Attendance -->
      <div class="mc-panel rank-panel">
        <h2 style="border-bottom: 2px solid #30363d; padding-bottom: 0.5rem; color: #f0f6fc;">Progress & Tier</h2>
        <div class="tier-box">
          <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.75rem;">
            <p style="color: #8b949e; margin: 0; font-size: 1rem; text-transform: uppercase;">Attendance</p>
            <p style="font-family: var(--font-minecraft-ten); color: var(--mc-accent); margin: 0; font-size: 1.25rem;">{user.daysAttended} / 5</p>
          </div>
          <div class="progress-bar">
            <div class="progress-fill" style={`width: ${(user.daysAttended / 5) * 100}%;`}></div>
          </div>
          <div style="margin-top: 2rem; display: flex; flex-direction: column; align-items: center; gap: 0.5rem;">
            <p style="color: #8b949e; font-size: 0.9rem; text-transform: uppercase; margin: 0;">Current Tier</p>
            <div style={`display: inline-block; padding: 0.5rem 1.5rem; background-color: #111; background-image: linear-gradient(135deg, rgba(0,0,0,0.6) 0%, rgba(255,255,255,0.05) 100%); border-radius: 8px; border: 1px solid ${user.rankColor}40; box-shadow: 0 0 15px ${user.rankColor}30, inset 0 1px 0 rgba(255,255,255,0.1);`}>
              <h3 style={`color: ${user.rankColor}; margin: 0; font-size: 2.25rem; letter-spacing: 2px; text-shadow: 1px 1px 0 #000, 0 0 15px ${user.rankColor}80;`}>{user.rank}</h3>
            </div>
          </div>
        </div>
      </div>

      <!-- Achievements/Badges -->
      <div class="mc-panel badges-panel">
        <h2 style="border-bottom: 2px solid #30363d; padding-bottom: 0.5rem; color: #f0f6fc;">Achievements</h2>
        <div class="badges-grid">
          {user.badges.map(badge => (
            <div class="badge-item">
              <div class="badge-icon-box">
                <img src={badge.icon} alt={badge.title} width="40" height="40" style="image-rendering: pixelated;" onerror="this.src='data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNkYAAAAAYAAjCB0C8AAAAASUVORK5CYII='"/>
              </div>
              <p class="badge-title">{badge.title}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .profile-container {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .profile-header {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    background: #161b22;
    border: 1px solid #30363d;
  }

  .avatar-box {
    width: 120px;
    height: 120px;
    min-width: 120px;
    min-height: 120px;
    flex-shrink: 0;
    border: 1px solid #30363d;
    background-color: #0d1117;
    border-radius: 8px;
    padding: 4px;
  }

  .avatar-head {
    width: 100%;
    height: 100%;
    object-fit: cover;
    image-rendering: pixelated;
    border-radius: 4px;
  }

  .player-info h1.player-name {
    margin: 0 0 0.75rem 0;
    color: #f0f6fc;
    font-size: 2.5rem;
  }

  .group-title {
    margin: 0 0 1rem 0;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .group-label {
    background-color: #30363d;
    color: #c9d1d9;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .group-name {
    color: #58a6ff;
    font-size: 1.25rem;
  }

  .emerald-count {
    font-size: 1.1rem;
    margin: 0;
    color: #8b949e;
    display: flex;
    align-items: center;
  }

  .profile-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .profile-details {
      grid-template-columns: 1fr;
    }

    .profile-header {
      flex-direction: column;
      text-align: center;
      gap: 1.5rem;
    }

    .group-title, .emerald-count {
      justify-content: center;
    }

    .player-info h1.player-name {
      font-size: 2rem; /* slightly smaller on mobile */
      word-break: break-word;
    }
  }

  .tier-box {
    padding: 1rem 0;
  }

  .progress-bar {
    background-color: #0d1117;
    border: 1px solid #30363d;
    height: 8px;
    width: 100%;
    border-radius: 4px;
    overflow: hidden;
  }

  .progress-fill {
    background-color: var(--mc-accent);
    height: 100%;
    box-shadow: 0 0 10px rgba(35, 134, 54, 0.5)
  }

  .badges-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
    gap: 1.5rem;
    padding-top: 1rem;
  }

  .badge-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
  }

  .badge-icon-box {
    width: 64px;
    height: 64px;
    background-color: #0d1117;
    background-image: linear-gradient(145deg, #161b22 0%, #0d1117 100%);
    border: 1px solid #30363d;
    border-radius: 8px;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: inset 0 1px 1px rgba(255,255,255,0.05);
  }

  .badge-icon-box:hover {
    transform: scale(1.1) translateY(-4px);
    border-color: #58a6ff;
    box-shadow: 0 8px 20px rgba(88, 166, 255, 0.4), inset 0 1px 1px rgba(255,255,255,0.2);
  }

  .badge-title {
    font-size: 0.85rem;
    color: #8b949e;
    margin: 0;
    line-height: 1.3;
